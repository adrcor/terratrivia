{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun"],
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",

    // Best practices
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Project references support
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",

    // Paths
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "cmd/**/*.ts"]
}
