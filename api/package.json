{
  "name": "server",
  "scripts": {
    "dev": "bun run --hot cmd/api.ts",
    "check": "bunx tsc --noEmit",
    "format": "prettier --write ./src",
    "db:drop": "bun cmd/drop_db.ts",
    "db:migrate": "bun db/migrate.ts",
    "db:generate": "atlas migrate diff --env local -c file://db/atlas.hcl",
    "db:diff": "atlas schema diff --from 'file://db/migrations?format=atlas' --to 'file://db/schema.sql' --env local -c file://db/atlas.hcl",
    "db:hash": "atlas migrate hash --env local -c file://db/atlas.hcl",
    "db:validate": "atlas migrate validate --env local -c file://db/atlas.hcl"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "better-auth": "^1.6.6",
    "hono": "^4.12.14",
    "kysely": "^0.28.16",
    "neverthrow": "^8.2.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "resend": "^6.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.12",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.3"
  }
}
